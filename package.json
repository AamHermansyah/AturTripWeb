  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter @atur-trip/web",
    "dev:api": "turbo dev --filter @atur-trip/api",
    "build": "turbo build",
    "build:web": "turbo build --filter @atur-trip/web",
    "build:api": "turbo build --filter @atur-trip/api",
