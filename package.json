{
  "name": "atur-trip",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter @atur-trip/web",
    "dev:api": "turbo dev --filter @atur-trip/api",
    "build": "turbo build",
    "build:web": "turbo build --filter @atur-trip/web",
    "build:api": "turbo build --filter @atur-trip/api",
    "start": "turbo start",
    "start:web": "turbo start --filter @atur-trip/web",
    "start:api": "turbo start --filter @atur-trip/api",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}
